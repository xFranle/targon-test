# Copy to the repo root as .env and fill in values.

# Required
HOTKEY_PHRASE=
VERSION=7.6.0
VALIDATOR_IP=

# Chain
CHAIN_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443
NETUID=4

# Weights API (alternative to HOTKEY_PHRASE for signing)
HOTKEY_PRIVATE_KEY=

# Mongo
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_HOST=mongo

# Optional
DISCORD_URL=
TOWER_URL=https://tower.targon.com
NVIDIA_ATTEST_ENDPOINT=http://nvidia-attest
ATTEST_RATE=.95
TIMEOUT_MULT=1
DEBUG=0
